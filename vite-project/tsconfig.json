{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "isolatedModules": true,
    "noEmit": true,
    "moduleResolution": "bundler"
  },
  "include": [],
  "exclude": ["node_modules", "dist"]
}
